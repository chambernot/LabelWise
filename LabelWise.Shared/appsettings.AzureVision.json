{
  "OCR": {
    // ═══════════════════════════════════════════════════════════════════════════
    // AZURE VISION READ OCR CONFIGURATION
    // ═══════════════════════════════════════════════════════════════════════════
    //
    // PROVIDERS DISPONÍVEIS:
    // ----------------------
    // 1. "Tesseract" - OCR local gratuito (requer tessdata)
    // 2. "AzureVision" - Azure AI Vision Read API (pago, alta precisão)
    // 3. "Selector" - Tesseract primeiro, Azure Vision se confiança baixa (RECOMENDADO)
    // 4. "Composite" - Configuração avançada com múltiplos providers
    // 5. "Mock" - Dados simulados (apenas para testes)
    //
    // ═══════════════════════════════════════════════════════════════════════════

    // OPÇÃO 1: SMART SELECTOR (RECOMENDADO) - Otimiza custo e qualidade
    // ------------------------------------------------------------------
    // Usa Tesseract primeiro (grátis). Se confiança < 85%, usa Azure Vision.
    "Provider": "Selector",

    "Selector": {
      // Se Tesseract retornar confiança < 85%, executa Azure Vision
      "UseAzureWhenTesseractConfidenceBelow": 0.85,

      // Se true, sempre executa ambos e escolhe o melhor (maior custo)
      "AlwaysExecuteBoth": false
    },

    // OPÇÃO 2: APENAS AZURE VISION - Máxima qualidade (maior custo)
    // --------------------------------------------------------------
    // Descomente abaixo para usar apenas Azure Vision
    // "Provider": "AzureVision",

    // OPÇÃO 3: APENAS TESSERACT - Gratuito (menor custo, menor qualidade)
    // --------------------------------------------------------------------
    // Descomente abaixo para usar apenas Tesseract
    // "Provider": "Tesseract",

    // ═══════════════════════════════════════════════════════════════════════════
    // CONFIGURAÇÃO DO AZURE AI VISION
    // ═══════════════════════════════════════════════════════════════════════════
    "AzureVision": {
      // Endpoint do recurso Azure AI Vision
      // Obtenha em: Portal Azure → Seu recurso → Keys and Endpoint
      "Endpoint": "https://YOUR-RESOURCE-NAME.cognitiveservices.azure.com/",

      // Chave de API (Key 1 ou Key 2)
      // Obtenha em: Portal Azure → Seu recurso → Keys and Endpoint
      "ApiKey": "YOUR-API-KEY-HERE",

      // Idioma preferencial (pt = Português, en = Inglês, es = Espanhol)
      "Language": "pt",

      // Timeout em segundos para chamadas à API
      "TimeoutSeconds": 30,

      // Se true, registra logs detalhados das chamadas Azure (debug)
      "EnableDetailedLogging": false,

      // Se true, valida conectividade com Azure na inicialização
      "ValidateOnStartup": false
    },

    // ═══════════════════════════════════════════════════════════════════════════
    // CONFIGURAÇÃO DO TESSERACT (usado pelo Selector)
    // ═══════════════════════════════════════════════════════════════════════════
    "TessdataPath": null, // null = auto-detect

    "Language": "por+eng", // Português + Inglês

    "ValidateOnStartup": true,

    // ═══════════════════════════════════════════════════════════════════════════
    // CONFIGURAÇÃO LEGADA (não usar para novos projetos)
    // ═══════════════════════════════════════════════════════════════════════════
    "Azure": {
      "Endpoint": null,
      "ApiKey": null,
      "ValidateOnStartup": false
    },

    "Composite": {
      "PrimaryProvider": "AzureVision",
      "FallbackProvider": "Tesseract",
      "ConfidenceThreshold": 0.85
    },

    // ═══════════════════════════════════════════════════════════════════════════
    // MOCK PROVIDER (apenas para testes)
    // ═══════════════════════════════════════════════════════════════════════════
    "UseMockProvider": false // Se true, usa dados simulados
  }
}
